{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pawin PyPOS",
  "version": "0.1.20",
  "identifier": "com.pawinplc.pypos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pawin PyPOS",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "visible": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      },
      {
        "label": "splashscreen",
        "url": "/splash.html",
        "width": 400,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "PawinPLC",
    "copyright": "© 2026 PawinPLC. All rights reserved.",
    "category": "Business",
    "shortDescription": "Stationery Inventory & POS",
    "longDescription": "A cross-platform Point of Sale and Inventory Management System designed specifically for Pawin PyPOS Stationery."
  }
}
