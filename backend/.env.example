# PyPOS Backend Environment Variables
# Copy this file to .env and fill in your Supabase credentials

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Alternative: Direct PostgreSQL connection string
# Get this from Supabase > Settings > Database
# DATABASE_URL=postgresql://postgres.[project-id]:[password]@db.[project-id].supabase.co:5432/postgres

# Server Configuration
HOST=0.0.0.0
PORT=8000
